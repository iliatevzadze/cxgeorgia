# Application
APP_ENV=local
APP_NAME=Georgian CX Platform
FRONTEND_PORT=3001
BACKEND_PORT=8000

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=15432
POSTGRES_DB=georgian_cx_platform
POSTGRES_USER=georgian_cx_user
POSTGRES_PASSWORD=change_me_local_only

# Backend database (SQLAlchemy async + Alembic)
BACKEND_DATABASE_MODE=local
BACKEND_DATABASE_URL_LOCAL=postgresql+asyncpg://georgian_cx_user:change_me_local_only@localhost:15432/georgian_cx_platform
BACKEND_DATABASE_URL_DOCKER=postgresql+asyncpg://georgian_cx_user:change_me_local_only@postgres:5432/georgian_cx_platform

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_HOST_PORT=16379

# Worker
WORKER_REDIS_MODE=local

# MinIO
MINIO_ENDPOINT=http://minio:9000
MINIO_ROOT_USER=minio_local_user
MINIO_ROOT_PASSWORD=change_me_local_only
MINIO_BUCKET_NAME=georgian-cx-local

# Mailpit
MAILPIT_SMTP_HOST=mailpit
MAILPIT_SMTP_PORT=1025
MAILPIT_WEB_PORT=8025

# Auth placeholders for future Phase 1 work
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_SECRET_KEY=change_me_local_only

# Internationalization
DEFAULT_LOCALE=ka
SUPPORTED_LOCALES=ka,en
